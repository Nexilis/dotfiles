# These config dirs are symlinked into this repo, so the apps read and write
# their state inside the repo working tree. Keep machine-generated and personal
# state out of git while letting it live alongside the tracked config.

# fish: universal variables + generated completions and tool integrations
config/fish/fish_variables
config/fish/completions/
config/fish/conf.d/

# nvim: plugin lockfile (noise, regenerated by lazy.nvim)
config/nvim/lazy-lock.json

# hammerspoon: installed Spoons (plugins)
config/hammerspoon/Spoons/

# zed: chats, prompts, downloaded themes, settings backups
config/zed/conversations/
config/zed/prompts/
config/zed/themes/
config/zed/settings_backup.json

# karabiner: generated assets and automatic backups
config/karabiner/assets/
config/karabiner/automatic_backups/

# Stray Claude Code local state that lands in a working directory
.claude/
.claude.json

# OS noise
.DS_Store
