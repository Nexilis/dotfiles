[user]
  name = Bartek Łukasik
# Work email is in ~/.gitconfig.local (gitignored, machine-local) so it is not
# committed to this public repo. Private dirs override the identity below.
[include]
  path = ~/.gitconfig.local
[includeIf "gitdir:~/code/gh/prv/"]
  path = ~/.gitconfig.prv
[includeIf "gitdir:~/Documents/sync/private-sync/"]
  path = ~/.gitconfig.prv
[core]
  autocrlf = input
  editor = vim
[credential]
	helper =
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
